---
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import GuideSidebar from '../components/guide/GuideSidebar.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'CLIX Guide',
  description = 'Install CLIX, set up AI tool integration, manage SSH hosts, and recover your workspace.',
} = Astro.props;
---

<Layout title={title} description={description}>
  <Nav />
  <div class="flex min-h-[calc(100vh-52px)]">
    <GuideSidebar />
    <main class="flex-1 py-10 px-14" style="max-width: 760px;">
      <slot />
    </main>
  </div>
</Layout>
