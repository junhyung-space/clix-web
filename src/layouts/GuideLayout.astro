---
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import GuideSidebar from '../components/guide/GuideSidebar.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'CLIX Guide',
  description = 'Install CLIX, set up AI tool integration, manage SSH hosts, and recover your workspace.',
} = Astro.props;
---

<Layout title={title} description={description}>
  <Nav />
  <div class="flex min-h-[calc(100vh-86px)] flex-col lg:min-h-[calc(100vh-73px)] lg:flex-row">
    <GuideSidebar />
    <main class="mx-auto w-full flex-1 px-4 py-8 sm:px-6 md:px-10 lg:mx-0 lg:px-14 lg:py-10" style="max-width: 760px;">
      <slot />
    </main>
  </div>
</Layout>
