---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'CLIX — AI 코딩 도구에 최적화된 macOS SSH 터미널',
  description = 'Claude Code, Codex, Gemini CLI와 함께 일하는 개발자를 위한 macOS SSH 터미널 워크스페이스.',
} = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/icon.png" />
    <!-- Inter font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-bg-primary text-text-primary font-sans antialiased">
    <slot />

    <script>
      import { ko } from '../i18n/ko';
      import { en } from '../i18n/en';

      type Lang = 'ko' | 'en';

      function detectLang(): Lang {
        const saved = localStorage.getItem('clix-lang') as Lang | null;
        if (saved === 'ko' || saved === 'en') return saved;
        return navigator.language.startsWith('ko') ? 'ko' : 'en';
      }

      function applyLang(lang: Lang) {
        const t = lang === 'ko' ? ko : en;
        document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
          const key = el.dataset.i18n!;
          const value = key.split('.').reduce((obj: any, k) => obj?.[k], t);
          if (typeof value === 'string') el.textContent = value;
        });
        document.documentElement.lang = lang;
        localStorage.setItem('clix-lang', lang);

        // Update toggle button
        const toggle = document.getElementById('lang-toggle');
        if (toggle) toggle.textContent = lang === 'ko' ? 'KO / EN' : 'EN / KO';
      }

      // Init on load
      const currentLang = detectLang();
      applyLang(currentLang);

      // Toggle on click
      document.getElementById('lang-toggle')?.addEventListener('click', () => {
        const next: Lang =
          (localStorage.getItem('clix-lang') as Lang) === 'ko' ? 'en' : 'ko';
        applyLang(next);
      });
    </script>
  </body>
</html>

<style is:global>
  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  }
  .grad-text {
    background: linear-gradient(160deg, #f8fafc 30%, #93c5fd 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .btn-primary {
    background: linear-gradient(135deg, #1d4ed8, #0ea5e9);
    box-shadow: 0 8px 30px rgba(14, 165, 233, 0.3);
  }
  .btn-primary:hover {
    box-shadow: 0 12px 40px rgba(14, 165, 233, 0.45);
    transform: translateY(-1px);
  }
  .card-top-line::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(59,130,246,0.4), transparent);
  }
</style>
