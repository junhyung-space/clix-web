---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'CLIX — SSH 호스트 관리, 포트 포워딩, AI CLI 작업 흐름을 지원하는 macOS 앱',
  description = 'SSH 호스트 관리, 포트 포워딩, AI CLI 작업 흐름을 한곳에서 지원하는 macOS 앱입니다.',
} = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/icon.png" />
    <!-- Inter font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-bg-primary text-text-primary font-sans antialiased">
    <slot />

    <script>
      import { ko } from '../i18n/ko';
      import { en } from '../i18n/en';

      type Lang = 'ko' | 'en';

      function detectLang(): Lang {
        const saved = localStorage.getItem('clix-lang') as Lang | null;
        if (saved === 'ko' || saved === 'en') return saved;
        return navigator.language.startsWith('ko') ? 'ko' : 'en';
      }

      function applyLang(lang: Lang) {
        const t = lang === 'ko' ? ko : en;
        document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
          const key = el.dataset.i18n!;
          const value = key.split('.').reduce((obj: any, k) => obj?.[k], t);
          if (typeof value === 'string') el.textContent = value;
        });
        document.documentElement.lang = lang;
        localStorage.setItem('clix-lang', lang);
        updateLangToggle(lang);
      }

      function updateLangToggle(lang: Lang) {
        const toggle = document.getElementById('lang-toggle');
        if (!toggle) return;

        const label = document.getElementById('lang-toggle-label');
        if (label) label.textContent = lang === 'ko' ? '한국어' : 'English';
        toggle.setAttribute('aria-label', lang === 'ko' ? 'Switch language to English' : 'Switch language to Korean');
        toggle.setAttribute('title', lang === 'ko' ? 'English로 전환' : 'Switch to Korean');
      }

      // Init on load
      const currentLang = detectLang();
      applyLang(currentLang);

      document.getElementById('lang-toggle')?.addEventListener('click', () => {
        const next: Lang =
          (localStorage.getItem('clix-lang') as Lang) === 'ko' ? 'en' : 'ko';
        applyLang(next);
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --section-px: clamp(1rem, 2.8vw, 4rem);
    --section-py: clamp(4rem, 8vw, 6rem);
    --content-max: 72rem;
    --copy-max: 42rem;
    --title-fluid-lg: clamp(2rem, 5vw, 3.5rem);
    --title-fluid-md: clamp(1.875rem, 4vw, 3rem);
    --title-fluid-sm: clamp(1.75rem, 3vw, 2.25rem);
    --body-fluid: clamp(0.95rem, 1.5vw, 1.0625rem);
  }
  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  }
  .section-shell {
    padding-inline: var(--section-px);
    padding-block: var(--section-py);
  }
  .section-inner {
    width: min(100%, var(--content-max));
    margin-inline: auto;
  }
  .section-kicker {
    display: inline-block;
    margin-bottom: 0.75rem;
    border-radius: 0.375rem;
    border: 1px solid rgba(96, 165, 250, 0.3);
    background: rgba(37, 99, 235, 0.12);
    padding: 0.125rem 0.625rem;
    color: #60a5fa;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .section-title {
    font-size: var(--title-fluid-md);
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.03em;
  }
  .section-copy {
    width: min(100%, var(--copy-max));
    margin-inline: auto;
    font-size: var(--body-fluid);
    line-height: 1.7;
    color: rgb(148 163 184 / 0.95);
  }
  .hero-title {
    max-width: min(100%, 18rem);
    margin-inline: auto;
    font-size: clamp(2.35rem, 8.8vw, 6rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.05em;
    text-wrap: balance;
  }
  .hero-copy {
    width: min(100%, 34rem);
    margin-inline: auto;
    font-size: clamp(1rem, 3.9vw, 1.125rem);
    line-height: 1.65;
    color: rgb(148 163 184 / 0.95);
    text-wrap: pretty;
  }
  .panel-card {
    border-radius: 1rem;
    border: 1px solid rgba(96, 165, 250, 0.14);
    background: rgba(255, 255, 255, 0.02);
  }
  .guide-shell {
    width: min(100%, 48rem);
  }
  .guide-kicker {
    margin-bottom: 0.75rem;
  }
  .guide-title {
    margin-bottom: 0.75rem;
    font-size: var(--title-fluid-sm);
    font-weight: 800;
    line-height: 1.12;
    letter-spacing: -0.03em;
    color: rgb(241 245 249);
  }
  .guide-copy {
    margin-bottom: 2rem;
    max-width: 42rem;
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgb(148 163 184 / 0.95);
  }
  .grad-text {
    background: linear-gradient(160deg, #f8fafc 30%, #93c5fd 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .btn-primary {
    background: linear-gradient(135deg, #1d4ed8, #0ea5e9);
    box-shadow: 0 8px 30px rgba(14, 165, 233, 0.3);
  }
  .btn-primary:hover {
    box-shadow: 0 12px 40px rgba(14, 165, 233, 0.45);
    transform: translateY(-1px);
  }
  .card-top-line::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(59,130,246,0.4), transparent);
  }
  @media (max-width: 1023px) {
    .guide-mobile-scroll {
      scrollbar-width: none;
    }
    .guide-mobile-scroll::-webkit-scrollbar {
      display: none;
    }
  }
  @media (min-width: 640px) {
    .hero-title {
      max-width: min(100%, 30rem);
    }
  }
  @media (min-width: 1024px) {
    .hero-title {
      max-width: min(100%, 56rem);
    }
  }
</style>
