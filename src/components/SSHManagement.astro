---
import SectionIconBadge from './SectionIconBadge.astro';
import { en } from '../i18n/en';

const cards = [
  { icon: 'collection', titleKey: 'ssh.card1Title', descKey: 'ssh.card1Desc',
    titleDefault: en.ssh.card1Title,
    descDefault: en.ssh.card1Desc },
  { icon: 'key', titleKey: 'ssh.card2Title', descKey: 'ssh.card2Desc',
    titleDefault: en.ssh.card2Title,
    descDefault: en.ssh.card2Desc },
  { icon: 'network', titleKey: 'ssh.card3Title', descKey: 'ssh.card3Desc',
    titleDefault: en.ssh.card3Title,
    descDefault: en.ssh.card3Desc },
  { icon: 'tunnel', titleKey: 'ssh.card4Title', descKey: 'ssh.card4Desc',
    titleDefault: en.ssh.card4Title,
    descDefault: en.ssh.card4Desc },
  { icon: 'bolt', titleKey: 'ssh.card5Title', descKey: 'ssh.card5Desc',
    titleDefault: en.ssh.card5Title,
    descDefault: en.ssh.card5Desc },
  { icon: 'search', titleKey: 'ssh.card6Title', descKey: 'ssh.card6Desc',
    titleDefault: en.ssh.card6Title,
    descDefault: en.ssh.card6Desc },
];
---

<section
  class="border-t border-white/[0.04] bg-bg-dark px-4 py-16 sm:px-6 sm:py-20 md:px-10 md:py-24 lg:px-16"
>
  <!-- Header -->
  <div class="mb-12 text-center sm:mb-14">
    <span
      class="inline-block bg-blue-muted/15 border border-blue-muted/30 text-blue-accent
             text-[10px] font-bold tracking-[3px] uppercase px-2.5 py-0.5 rounded mb-3"
      data-i18n="ssh.label"
    >{en.ssh.label}</span>
    <h2 class="text-3xl font-extrabold tracking-tight sm:text-4xl md:text-5xl">
      <span class="grad-text" data-i18n="ssh.title1">{en.ssh.title1}</span>
      <br />
      <span class="grad-text" data-i18n="ssh.title2">{en.ssh.title2}</span>
    </h2>
    <p class="mt-3 text-sm text-white/72 sm:text-base" data-i18n="ssh.sub">
      {en.ssh.sub}
    </p>
  </div>

  <!-- Grid -->
  <div class="mx-auto grid max-w-5xl grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3">
    {cards.map(c => (
      <div
        class="rounded-2xl border border-white/[0.06] bg-white/[0.02] p-5 sm:p-6 md:p-7
               hover:border-blue-muted/20 transition-colors duration-200"
      >
        <div class="mb-3.5">
          <SectionIconBadge name={c.icon} />
        </div>
        <h3 class="text-base font-bold text-text-primary mb-2" data-i18n={c.titleKey}>
          {c.titleDefault}
        </h3>
        <p class="text-xs leading-relaxed text-white/68" data-i18n={c.descKey}>
          {c.descDefault}
        </p>
      </div>
    ))}
  </div>
</section>
