---
import { en } from '../i18n/en';
---

<section
  class="border-t border-white/[0.04] bg-bg-primary px-4 py-16 text-center sm:px-6 sm:py-20 md:px-10 md:py-24 lg:px-16"
>
  <span
    class="inline-block bg-blue-muted/15 border border-blue-muted/30 text-blue-accent
           text-[10px] font-bold tracking-[3px] uppercase px-2.5 py-0.5 rounded mb-3"
    data-i18n="preview.label"
  >{en.preview.label}</span>
  <h2 class="mb-2 text-3xl font-extrabold tracking-tight sm:text-4xl">
    <span class="grad-text" data-i18n="preview.title">{en.preview.title}</span>
  </h2>
  <p class="mx-auto mb-8 max-w-2xl text-sm text-white/72 sm:mb-10" data-i18n="preview.sub">{en.preview.sub}</p>

  <div
    class="mx-auto max-w-4xl overflow-hidden rounded-2xl"
    style="background: #0d1320; border: 1px solid rgba(59,130,246,0.18); box-shadow: 0 0 100px rgba(14,165,233,0.1), 0 60px 100px rgba(0,0,0,0.5);"
  >
    <img
      src="/images/clix-app-preview.png"
      alt="CLIX app preview screenshot"
      class="block w-full h-auto"
      loading="lazy"
    />
  </div>

  <p class="mt-5 text-sm text-white/68 sm:mt-6" data-i18n="preview.placeholder">
    {en.preview.placeholder}
  </p>
</section>
