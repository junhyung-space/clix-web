---
const features = [
  { icon: '🗂', titleKey: 'workspace.feat1Title', descKey: 'workspace.feat1Desc',
    titleDefault: '멀티탭 & 분할 패인',
    descDefault: '여러 서버 세션을 탭과 좌우·상하 분할로 동시에 관리. 복잡한 레이아웃도 자유롭게.' },
  { icon: '💾', titleKey: 'workspace.feat2Title', descKey: 'workspace.feat2Desc',
    titleDefault: '워크스페이스 복구',
    descDefault: '앱 재시작 후에도 탭·패인 레이아웃과 작업 디렉토리가 그대로 복원됩니다.' },
  { icon: '⚡', titleKey: 'workspace.feat3Title', descKey: 'workspace.feat3Desc',
    titleDefault: 'Ghostty 엔진',
    descDefault: '최신 Ghostty/libghostty 기반의 네이티브 렌더링. 빠르고 정확한 터미널 에뮬레이션.' },
];
---

<section
  class="px-16 py-24 border-t border-white/[0.04] bg-bg-secondary"
>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-20 items-center max-w-5xl mx-auto">

    <!-- Left: Text -->
    <div>
      <span
        class="inline-block bg-blue-muted/15 border border-blue-muted/30 text-blue-accent
               text-[10px] font-bold tracking-[3px] uppercase px-2.5 py-0.5 rounded mb-3"
        data-i18n="workspace.label"
      >Terminal Workspace</span>
      <h2 class="text-4xl font-extrabold tracking-tight leading-tight mb-3">
        <span class="grad-text" data-i18n="workspace.title1">복잡한 작업도</span>
        <br />
        <span class="grad-text" data-i18n="workspace.title2">한 화면에서</span>
      </h2>
      <p class="text-text-muted text-sm leading-relaxed" data-i18n="workspace.sub">
        멀티탭, 분할 패인, 세션 복구 — Ghostty 엔진의 빠른 네이티브 터미널 경험
      </p>

      <div class="mt-8 flex flex-col gap-5">
        {features.map(f => (
          <div class="flex items-start gap-4">
            <div
              class="w-9 h-9 rounded-lg flex items-center justify-center text-base flex-shrink-0"
              style="background: rgba(29,78,216,0.2); border: 1px solid rgba(59,130,246,0.2);"
            >{f.icon}</div>
            <div>
              <h4 class="text-sm font-semibold text-text-primary mb-1" data-i18n={f.titleKey}>
                {f.titleDefault}
              </h4>
              <p class="text-xs text-text-muted leading-relaxed" data-i18n={f.descKey}>
                {f.descDefault}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Right: Terminal Mockup -->
    <div
      class="rounded-2xl overflow-hidden"
      style="background: #0d1117; border: 1px solid rgba(59,130,246,0.2); box-shadow: 0 0 60px rgba(14,165,233,0.08), 0 30px 60px rgba(0,0,0,0.4);"
    >
      <!-- Title bar -->
      <div class="flex items-center gap-2 px-4 py-3 border-b border-white/[0.05]" style="background: #111827;">
        <span class="w-3 h-3 rounded-full" style="background:#ff5f57;"></span>
        <span class="w-3 h-3 rounded-full" style="background:#febc2e;"></span>
        <span class="w-3 h-3 rounded-full" style="background:#28c840;"></span>
        <span class="text-text-darkest text-xs font-mono ml-2">CLIX — prod · staging</span>
      </div>
      <!-- Split panes -->
      <div class="grid grid-cols-2 divide-x divide-white/[0.04]">
        <div class="p-4 font-mono text-xs min-h-[200px]">
          <div class="text-blue-dim font-bold mb-2 text-[10px] tracking-wide">⬤ prod-server</div>
          <div class="text-text-darkest">$ git pull origin main</div>
          <div class="text-text-secondary mt-1">Already up to date.</div>
          <div class="text-text-darkest mt-2">$ docker compose up -d</div>
          <div class="text-green-500 mt-1">✓ 3 containers started</div>
          <div class="mt-2 text-text-secondary">$ <span class="inline-block w-2 h-3 bg-blue-muted align-middle"></span></div>
        </div>
        <div class="p-4 font-mono text-xs min-h-[200px]">
          <div class="text-blue-dim font-bold mb-2 text-[10px] tracking-wide">⬤ staging-server</div>
          <div class="text-text-darkest">$ claude "analyze server logs"</div>
          <div class="text-blue-muted mt-1">... analyzing ...</div>
          <div class="text-text-secondary mt-2">→ waiting for notification</div>
          <div class="mt-4 text-text-secondary">$ <span class="inline-block w-2 h-3 bg-blue-muted align-middle"></span></div>
        </div>
      </div>
    </div>

  </div>
</section>
