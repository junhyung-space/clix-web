---
import SectionIconBadge from './SectionIconBadge.astro';
import { en } from '../i18n/en';

const features = [
  { icon: 'layers', titleKey: 'workspace.feat1Title', descKey: 'workspace.feat1Desc',
    titleDefault: en.workspace.feat1Title,
    descDefault: en.workspace.feat1Desc },
  { icon: 'terminal', titleKey: 'workspace.feat2Title', descKey: 'workspace.feat2Desc',
    titleDefault: en.workspace.feat2Title,
    descDefault: en.workspace.feat2Desc },
  { icon: 'history', titleKey: 'workspace.feat3Title', descKey: 'workspace.feat3Desc',
    titleDefault: en.workspace.feat3Title,
    descDefault: en.workspace.feat3Desc },
];
---

<section
  class="border-t border-white/[0.04] bg-bg-secondary px-4 py-16 sm:px-6 sm:py-20 md:px-10 md:py-24 lg:px-16"
>
  <div class="mx-auto grid max-w-5xl grid-cols-1 items-center gap-12 md:grid-cols-2 md:gap-16 lg:gap-20">

    <!-- Left: Text -->
    <div>
      <span
        class="inline-block bg-blue-muted/15 border border-blue-muted/30 text-blue-accent
               text-[10px] font-bold tracking-[3px] uppercase px-2.5 py-0.5 rounded mb-3"
        data-i18n="workspace.label"
      >{en.workspace.label}</span>
      <h2 class="mb-3 text-3xl font-extrabold tracking-tight leading-tight sm:text-4xl">
        <span class="grad-text" data-i18n="workspace.title1">{en.workspace.title1}</span>
        <br />
        <span class="grad-text" data-i18n="workspace.title2">{en.workspace.title2}</span>
      </h2>
      <p class="text-sm leading-relaxed text-white/72" data-i18n="workspace.sub">
        {en.workspace.sub}
      </p>

      <div class="mt-8 flex flex-col gap-5">
        {features.map(f => (
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0">
              <SectionIconBadge name={f.icon} size="sm" />
            </div>
            <div>
              <h4 class="text-sm font-semibold text-text-primary mb-1" data-i18n={f.titleKey}>
                {f.titleDefault}
              </h4>
              <p class="text-xs leading-relaxed text-white/68" data-i18n={f.descKey}>
                {f.descDefault}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Right: Terminal screenshot -->
    <div
      class="overflow-hidden rounded-2xl"
      style="background: #0d1117; border: 1px solid rgba(59,130,246,0.2); box-shadow: 0 0 60px rgba(14,165,233,0.08), 0 30px 60px rgba(0,0,0,0.4);"
    >
      <img
        src="/images/clix-terminal-workspace.png"
        alt="CLIX terminal workspace screenshot"
        class="block w-full h-auto"
        loading="lazy"
      />
    </div>

  </div>
</section>
