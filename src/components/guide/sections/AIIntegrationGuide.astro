---
import { en } from '../../../i18n/en';

const guide = en.guide.ai;
---
<div id="ai-integration" class="guide-section guide-shell">
  <p class="guide-kicker text-blue-accent text-[10px] font-bold tracking-[0.1em] uppercase" data-i18n="guide.ai.label">{guide.label}</p>
  <h2 class="guide-title" data-i18n="guide.ai.title">{guide.title}</h2>
  <p class="guide-copy" data-i18n="guide.ai.sub">
    {guide.sub}
  </p>

  <div class="guide-summary">
    <p class="guide-summary-title" data-i18n="guide.common.whatYoullDo">{en.guide.common.whatYoullDo}</p>
    <ul class="guide-summary-list">
      <li data-i18n="guide.ai.scopeTitle">{guide.scopeTitle}</li>
      <li data-i18n="guide.ai.notifyTitle">{guide.notifyTitle}</li>
      <li data-i18n="guide.ai.pickTitle">{guide.pickTitle}</li>
    </ul>
  </div>

  <section class="guide-section-block">
    <h3 class="guide-subtitle" data-i18n="guide.ai.scopeTitle">{guide.scopeTitle}</h3>
    <p class="guide-prose" data-i18n="guide.ai.scopeDesc">
      {guide.scopeDesc}
    </p>
  </section>

  <div class="guide-callout">
    <h3 class="guide-subtitle !mb-2" data-i18n="guide.ai.zshTitle">{guide.zshTitle}</h3>
    <p class="guide-prose" data-i18n="guide.ai.zshDesc">
      {guide.zshDesc}
    </p>
  </div>

  {[
    {
      titleKey: 'guide.ai.notifyTitle',
      descKey: 'guide.ai.notifyDesc',
      titleDefault: guide.notifyTitle,
      descDefault: guide.notifyDesc,
    },
    {
      titleKey: 'guide.ai.sessionsTitle',
      descKey: 'guide.ai.sessionsDesc',
      titleDefault: guide.sessionsTitle,
      descDefault: guide.sessionsDesc,
    },
    {
      titleKey: 'guide.ai.handoffTitle',
      descKey: 'guide.ai.handoffDesc',
      titleDefault: guide.handoffTitle,
      descDefault: guide.handoffDesc,
    },
    {
      titleKey: 'guide.ai.pickTitle',
      descKey: 'guide.ai.pickDesc',
      titleDefault: guide.pickTitle,
      descDefault: guide.pickDesc,
    },
  ].map(({ titleKey, descKey, titleDefault, descDefault }) => (
    <section class="guide-section-block">
      <h3 class="guide-subtitle" data-i18n={titleKey}>{titleDefault}</h3>
      <p class="guide-prose" data-i18n={descKey}>{descDefault}</p>
    </section>
  ))}

  <div class="guide-code">
    <div class="guide-code-line-muted" data-i18n="guide.ai.exampleLine1">{guide.exampleLine1}</div>
    <div class="guide-code-line" data-i18n="guide.ai.exampleLine2">{guide.exampleLine2}</div>
    <div class="guide-code-line-muted mt-2" data-i18n="guide.ai.exampleLine3">{guide.exampleLine3}</div>
    <div class="guide-code-line" data-i18n="guide.ai.exampleLine4">{guide.exampleLine4}</div>
    <div class="guide-code-line-muted mt-2" data-i18n="guide.ai.exampleLine5">{guide.exampleLine5}</div>
    <div class="guide-code-line" data-i18n="guide.ai.exampleLine6">{guide.exampleLine6}</div>
  </div>

  <div class="guide-next">
    <p class="guide-next-label" data-i18n="guide.common.nextStep">{en.guide.common.nextStep}</p>
    <p class="guide-next-copy" data-i18n="guide.ai.nextStep">
      {guide.nextStep}
    </p>
  </div>
</div>
