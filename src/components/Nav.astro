---
const isGuide = Astro.url.pathname.startsWith('/guide');

const guideSections = [
  { section: 'getting-started', key: 'guide.sidebar.gettingStarted', defaultText: '시작하기' },
  { section: 'ai-integration', key: 'guide.sidebar.ai', defaultText: 'AI 도구 연동' },
  { section: 'workspace', key: 'guide.sidebar.workspace', defaultText: '워크스페이스' },
  { section: 'ssh', key: 'guide.sidebar.ssh', defaultText: '호스트와 SSH' },
  { section: 'port-forwarding', key: 'guide.sidebar.portForwarding', defaultText: '포트 포워딩' },
  { section: 'backup', key: 'guide.sidebar.backup', defaultText: '백업과 복원' },
  { section: 'settings', key: 'guide.sidebar.settings', defaultText: '설정' },
];
---

<nav
  class="sticky top-0 z-50 px-4 py-3 sm:px-6 md:px-10 lg:px-16
         bg-bg-primary/90 border-b border-blue-muted/10 backdrop-blur-xl"
>
  <div class="mx-auto flex w-full max-w-7xl items-center justify-between gap-3 md:grid md:grid-cols-[auto_1fr_auto] md:gap-6">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 no-underline sm:gap-3">
      <div class="h-9 w-9 sm:h-10 sm:w-10 md:h-12 md:w-12 lg:h-14 lg:w-14">
        <img
          src="/icon.png"
          alt="CLIX"
          class="h-full w-full object-contain"
        />
      </div>
      <span class="font-extrabold text-base tracking-[2px] text-text-primary sm:text-lg md:text-xl md:tracking-[3px]">
        CLIX
      </span>
    </a>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-toggle"
      type="button"
      class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/[0.08]
             bg-white/[0.03] text-text-primary transition-colors hover:border-blue-muted/30
             hover:bg-white/[0.05] md:hidden"
      aria-label="Open navigation"
      aria-expanded="false"
      aria-controls="mobile-menu-panel"
    >
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.9"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="h-5 w-5"
        aria-hidden="true"
      >
        <path d="M4 7h16" />
        <path d="M4 12h16" />
        <path d="M4 17h16" />
      </svg>
    </button>

    <!-- Utilities -->
    <div class="ml-auto hidden items-center gap-2 sm:gap-3 md:order-3 md:flex md:justify-self-end">
      <button
        data-lang-toggle
        type="button"
        class="group inline-flex h-8 items-center gap-1.5 rounded-full border border-white/[0.08]
               bg-white/[0.04] px-2.5 text-[11px] font-semibold text-text-primary/88
               shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] cursor-pointer
               transition-all duration-150 hover:border-blue-muted/30 hover:bg-white/[0.06]
               hover:text-text-primary active:scale-[0.98] sm:h-9 sm:gap-2 sm:px-3 sm:text-[12px]"
        aria-label="Toggle language"
      >
        <span
          class="flex h-5 w-5 items-center justify-center rounded-full bg-blue-deep/35
                 text-blue-200 transition-colors group-hover:bg-blue-deep/45"
          aria-hidden="true"
        >
          <svg
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-3.5 w-3.5"
          >
            <path d="M3 5.25h10" />
            <path d="M9.5 2.75L13 5.25 9.5 7.75" />
            <path d="M13 10.75H3" />
            <path d="M6.5 8.25L3 10.75l3.5 2.5" />
          </svg>
        </span>
        <span data-lang-toggle-label class="tracking-[0.01em]">한국어</span>
        <svg
          viewBox="0 0 12 12"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-3 w-3 opacity-70 transition-transform group-hover:translate-x-[1px]"
          aria-hidden="true"
        >
          <path d="M4 2.5 8 6 4 9.5" />
        </svg>
      </button>

      <a
        href="https://github.com/junhyung-space/clix/releases/latest/download/CLIX.zip"
        class="btn-primary inline-flex h-8 items-center rounded-lg px-3 text-[11px] font-semibold
               text-white sm:h-9 sm:px-3.5 sm:text-sm"
        data-i18n="nav.download"
      >
        다운로드
      </a>
    </div>

    <!-- Center menu -->
    <div class="order-3 hidden w-full justify-center md:order-2 md:flex md:w-auto md:justify-self-center">
      <a
        href="/guide"
        class={`inline-flex h-9 items-center rounded-full border px-4 text-[13px] font-semibold
                transition-all duration-150 ${
          isGuide
            ? 'border-blue-accent/25 bg-blue-deep/25 text-text-primary shadow-[0_8px_24px_rgba(37,99,235,0.16)]'
            : 'border-white/[0.08] bg-white/[0.03] text-text-primary/92 hover:border-blue-muted/30 hover:bg-white/[0.05] hover:text-text-primary'
        } sm:h-10 sm:px-5 sm:text-sm`}
      >
        <span data-i18n="nav.guide">가이드</span>
      </a>
    </div>
  </div>

  <div
    id="mobile-menu-panel"
    class={`fixed z-[60] hidden md:hidden ${
      isGuide
        ? 'inset-0 bg-[#060b15]/82 px-4 py-5 backdrop-blur-2xl sm:px-6'
        : 'left-4 right-4 top-[76px] rounded-[1.75rem] border border-white/[0.08] bg-[#0a1020]/96 p-4 shadow-[0_30px_80px_rgba(0,0,0,0.45)] backdrop-blur-2xl'
    }`}
  >
    <div class={`mx-auto flex w-full flex-col ${isGuide ? 'h-full max-w-3xl' : 'max-w-md'}`}>
      <div class="flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5 no-underline sm:gap-3" data-mobile-menu-close>
          <div class="h-9 w-9 sm:h-10 sm:w-10">
            <img
              src="/icon.png"
              alt="CLIX"
              class="h-full w-full object-contain"
            />
          </div>
          <span class="font-extrabold text-base tracking-[2px] text-text-primary sm:text-lg">
            CLIX
          </span>
        </a>

        <button
          type="button"
          class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/[0.08]
                 bg-white/[0.03] text-text-primary transition-colors hover:border-blue-muted/30
                 hover:bg-white/[0.05]"
          aria-label="Close navigation"
          data-mobile-menu-close
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.9"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-5 w-5"
            aria-hidden="true"
          >
            <path d="M6 6 18 18" />
            <path d="M18 6 6 18" />
          </svg>
        </button>
      </div>

      {isGuide ? (
        <>
          <div class="mt-5 h-px bg-white/[0.08]"></div>

          <div class="flex flex-1 flex-col justify-between py-7">
            <div class="space-y-1.5">
              {guideSections.map(({ section, key, defaultText }) => (
                <button
                  data-section={section}
                  data-mobile-menu-close
                  class="guide-sidebar-item flex w-full items-center gap-3 rounded-2xl px-1 py-2.5 text-left
                         text-[1.2rem] font-semibold tracking-[-0.03em] text-text-primary transition-colors
                         hover:text-blue-100 sm:text-[1.35rem]"
                >
                  <span class="h-2 w-2 flex-shrink-0 rounded-full bg-current opacity-55"></span>
                  <span data-i18n={key}>{defaultText}</span>
                </button>
              ))}
            </div>

            <div class="grid grid-cols-2 gap-3 pt-7">
              <button
                data-lang-toggle
                type="button"
                class="inline-flex h-12 items-center justify-center rounded-2xl border border-white/[0.12]
                       bg-white/[0.02] px-4 text-sm font-semibold text-text-primary transition-colors
                       hover:border-blue-muted/30 hover:bg-white/[0.04]"
                aria-label="Toggle language"
              >
                <span data-lang-toggle-label>한국어</span>
              </button>

              <a
                href="https://github.com/junhyung-space/clix/releases/latest/download/CLIX.zip"
                class="btn-primary inline-flex h-12 items-center justify-center rounded-2xl px-4
                       text-sm font-semibold text-white"
                data-i18n="nav.download"
              >
                다운로드
              </a>
            </div>
          </div>
        </>
      ) : (
        <div class="mt-4 space-y-3">
          <a
            href="/guide"
            class="flex items-center justify-between rounded-2xl border border-white/[0.08]
                   bg-white/[0.03] px-4 py-4 no-underline transition-colors hover:border-blue-muted/30
                   hover:bg-white/[0.05]"
            data-mobile-menu-close
          >
            <div class="flex items-center gap-3">
              <span class="h-2 w-2 flex-shrink-0 rounded-full bg-blue-200/80"></span>
              <div>
                <div class="text-lg font-semibold tracking-[-0.03em] text-text-primary" data-i18n="nav.guide">
                  가이드
                </div>
                <div class="mt-1 text-sm text-text-muted">
                  설치와 주요 기능 보기
                </div>
              </div>
            </div>
            <svg
              viewBox="0 0 20 20"
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-4 w-4 text-text-secondary"
              aria-hidden="true"
            >
              <path d="M7 4.5 12.5 10 7 15.5" />
            </svg>
          </a>

          <div class="grid grid-cols-2 gap-3">
            <button
              data-lang-toggle
              type="button"
              class="inline-flex h-12 items-center justify-center rounded-2xl border border-white/[0.12]
                     bg-white/[0.02] px-4 text-sm font-semibold text-text-primary transition-colors
                     hover:border-blue-muted/30 hover:bg-white/[0.04]"
              aria-label="Toggle language"
            >
              <span data-lang-toggle-label>한국어</span>
            </button>

            <a
              href="https://github.com/junhyung-space/clix/releases/latest/download/CLIX.zip"
              class="btn-primary inline-flex h-12 items-center justify-center rounded-2xl px-4
                     text-sm font-semibold text-white"
              data-i18n="nav.download"
            >
              다운로드
            </a>
          </div>
        </div>
      )}
    </div>
  </div>
</nav>
