---
const isGuide = Astro.url.pathname.startsWith('/guide');
---

<nav
  class="sticky top-0 z-50 px-4 py-3 sm:px-6 md:px-10 lg:px-16
         bg-bg-primary/90 border-b border-blue-muted/10 backdrop-blur-xl"
>
  <div class="mx-auto flex w-full max-w-7xl flex-wrap items-center gap-3 md:grid md:grid-cols-[auto_1fr_auto] md:gap-6">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 no-underline sm:gap-3">
      <div class="h-9 w-9 sm:h-10 sm:w-10 md:h-12 md:w-12 lg:h-14 lg:w-14">
        <img
          src="/icon.png"
          alt="CLIX"
          class="h-full w-full object-contain"
        />
      </div>
      <span class="font-extrabold text-base tracking-[2px] text-text-primary sm:text-lg md:text-xl md:tracking-[3px]">
        CLIX
      </span>
    </a>

    <!-- Utilities -->
    <div class="ml-auto flex items-center gap-2 sm:gap-3 md:order-3 md:justify-self-end">
      <button
        id="lang-toggle"
        type="button"
        class="group inline-flex h-8 items-center gap-1.5 rounded-full border border-white/[0.08]
               bg-white/[0.04] px-2.5 text-[11px] font-semibold text-text-primary/88
               shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] cursor-pointer
               transition-all duration-150 hover:border-blue-muted/30 hover:bg-white/[0.06]
               hover:text-text-primary active:scale-[0.98] sm:h-9 sm:gap-2 sm:px-3 sm:text-[12px]"
        aria-label="Toggle language"
      >
        <span
          class="flex h-5 w-5 items-center justify-center rounded-full bg-blue-deep/35
                 text-blue-200 transition-colors group-hover:bg-blue-deep/45"
          aria-hidden="true"
        >
          <svg
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-3.5 w-3.5"
          >
            <path d="M3 5.25h10" />
            <path d="M9.5 2.75L13 5.25 9.5 7.75" />
            <path d="M13 10.75H3" />
            <path d="M6.5 8.25L3 10.75l3.5 2.5" />
          </svg>
        </span>
        <span id="lang-toggle-label" class="tracking-[0.01em]">한국어</span>
        <svg
          viewBox="0 0 12 12"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-3 w-3 opacity-70 transition-transform group-hover:translate-x-[1px]"
          aria-hidden="true"
        >
          <path d="M4 2.5 8 6 4 9.5" />
        </svg>
      </button>

      <span
        class="btn-primary inline-flex h-8 items-center rounded-lg px-3 text-[11px] font-semibold
               text-white opacity-70 select-none sm:h-9 sm:px-3.5 sm:text-sm"
        data-i18n="nav.download"
      >
        출시 예정
      </span>
    </div>

    <!-- Center menu -->
    <div class="order-3 flex w-full justify-center md:order-2 md:w-auto md:justify-self-center">
      <a
        href="/guide"
        class={`inline-flex h-9 items-center rounded-full border px-4 text-[13px] font-semibold
                transition-all duration-150 ${
          isGuide
            ? 'border-blue-accent/25 bg-blue-deep/25 text-text-primary shadow-[0_8px_24px_rgba(37,99,235,0.16)]'
            : 'border-white/[0.08] bg-white/[0.03] text-text-primary/92 hover:border-blue-muted/30 hover:bg-white/[0.05] hover:text-text-primary'
        } sm:h-10 sm:px-5 sm:text-sm`}
      >
        <span data-i18n="nav.guide">가이드</span>
      </a>
    </div>
  </div>
</nav>
