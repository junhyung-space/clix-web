---
import { en } from '../i18n/en';
import { RELEASE_DOWNLOAD_URL } from '../config/release';

const isGuide = Astro.url.pathname.startsWith('/guide');

const guideSections = [
  { section: 'getting-started', key: 'guide.sidebar.gettingStarted', defaultText: en.guide.sidebar.gettingStarted },
  { section: 'ssh',             key: 'guide.sidebar.ssh',            defaultText: en.guide.sidebar.ssh },
  { section: 'port-forwarding', key: 'guide.sidebar.portForwarding', defaultText: en.guide.sidebar.portForwarding },
  { section: 'workspace',       key: 'guide.sidebar.workspace',      defaultText: en.guide.sidebar.workspace },
  { section: 'ai-integration',  key: 'guide.sidebar.ai',             defaultText: en.guide.sidebar.ai },
  { section: 'browser',         key: 'guide.sidebar.browser',        defaultText: en.guide.sidebar.browser },
  { section: 'backup',          key: 'guide.sidebar.backup',         defaultText: en.guide.sidebar.backup },
  { section: 'settings',        key: 'guide.sidebar.settings',       defaultText: en.guide.sidebar.settings },
];
---

<nav
  class="sticky top-0 z-50 px-4 py-3 sm:px-6 md:px-10 lg:px-16
         border-b border-white/[0.07] bg-[#07101b]/82 backdrop-blur-2xl"
>
  <div class="mx-auto flex w-full max-w-7xl items-center justify-between gap-3 md:gap-6">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 no-underline sm:gap-3">
      <div class="h-9 w-9 sm:h-10 sm:w-10 md:h-12 md:w-12 lg:h-14 lg:w-14">
        <img
          src="/icon.png"
          alt="CLIX"
          class="h-full w-full object-contain"
        />
      </div>
      <span class="brand-mark text-base sm:text-lg md:text-xl md:tracking-[0.22em]">
        CLIX
      </span>
    </a>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-toggle"
      type="button"
      class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/[0.08]
             bg-white/[0.035] text-white/96 shadow-[inset_0_1px_0_rgba(255,255,255,0.05)]
             transition-colors hover:border-white/18 hover:bg-white/[0.06] md:hidden"
      aria-label="Open navigation"
      aria-expanded="false"
      aria-controls="mobile-menu-panel"
    >
      <!-- Hamburger icon -->
      <svg
        id="menu-icon-hamburger"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.9"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="h-5 w-5"
        aria-hidden="true"
      >
        <path d="M4 7h16" />
        <path d="M4 12h16" />
        <path d="M4 17h16" />
      </svg>
      <!-- X icon (shown when menu is open) -->
      <svg
        id="menu-icon-x"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.9"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="h-5 w-5 hidden"
        aria-hidden="true"
      >
        <path d="M6 6 18 18" />
        <path d="M18 6 6 18" />
      </svg>
    </button>

    <!-- Desktop utilities -->
    <div class="ml-auto hidden items-center gap-2 sm:gap-3 md:flex">
      <a
        href="/guide"
        class={`inline-flex h-8 items-center rounded-full border px-2.5 text-[11px] font-bold
                transition-all duration-150 sm:h-9 sm:px-3 sm:text-[12px] ${
          isGuide
            ? 'border-white/[0.14] bg-white/[0.08] text-white shadow-[inset_0_1px_0_rgba(255,255,255,0.05)]'
            : 'border-white/[0.1] bg-white/[0.03] text-white/88 hover:border-white/[0.16] hover:bg-white/[0.06] hover:text-white'
        }`}
        data-i18n="nav.guide"
      >
        {en.nav.guide}
      </a>

      <button
        data-lang-toggle
        type="button"
        class="group inline-flex h-8 items-center gap-1.5 rounded-full border border-white/[0.08]
               bg-white/[0.03] px-2.5 text-[11px] font-semibold text-white/90
               shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] cursor-pointer
               transition-all duration-150 hover:border-white/[0.16] hover:bg-white/[0.05]
               hover:text-white active:scale-[0.98] sm:h-9 sm:gap-2 sm:px-3 sm:text-[12px]"
        aria-label="Toggle language"
      >
        <span
          class="flex h-5 w-5 items-center justify-center rounded-full border border-white/[0.06]
                 bg-[#13213b] text-[#a8dcff] transition-colors group-hover:bg-[#162846]"
          aria-hidden="true"
        >
          <svg
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-3.5 w-3.5"
          >
            <path d="M3 5.25h10" />
            <path d="M9.5 2.75L13 5.25 9.5 7.75" />
            <path d="M13 10.75H3" />
            <path d="M6.5 8.25L3 10.75l3.5 2.5" />
          </svg>
        </span>
        <span data-lang-toggle-label class="tracking-[0.01em]">English</span>
        <svg
          viewBox="0 0 12 12"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-3 w-3 opacity-70 transition-transform group-hover:translate-x-[1px]"
          aria-hidden="true"
        >
          <path d="M4 2.5 8 6 4 9.5" />
        </svg>
      </button>

      <a
        href={RELEASE_DOWNLOAD_URL}
        download
        class="btn-primary inline-flex h-8 items-center rounded-lg px-3 text-[11px] font-semibold
               text-white sm:h-9 sm:px-3.5 sm:text-sm"
        data-i18n="nav.download"
      >
        {en.nav.download}
      </a>
    </div>
  </div>
</nav>

<!-- Full-screen mobile menu panel (outside nav to avoid backdrop-filter containing block) -->
<div
  id="mobile-menu-panel"
  class="fixed inset-0 z-[60] flex flex-col bg-[#060b14]/94 backdrop-blur-2xl md:hidden"
  aria-hidden="true"
>
  <!-- Panel header (matches nav height) -->
  <div class="flex shrink-0 items-center justify-between border-b border-white/[0.08] px-4 py-3 sm:px-6">
    <a href="/" class="flex items-center gap-2.5 no-underline sm:gap-3" data-mobile-menu-close>
      <div class="h-9 w-9 sm:h-10 sm:w-10">
        <img src="/icon.png" alt="CLIX" class="h-full w-full object-contain" />
      </div>
      <span class="brand-mark text-base sm:text-lg">CLIX</span>
    </a>
    <button
      data-mobile-menu-close
      type="button"
      class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/[0.08]
             bg-white/[0.03] text-white/96 transition-colors hover:border-white/[0.18] hover:bg-white/[0.06]"
      aria-label="Close menu"
    >
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.9"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="h-5 w-5"
        aria-hidden="true"
      >
        <path d="M6 6 18 18" />
        <path d="M18 6 6 18" />
      </svg>
    </button>
  </div>

  <!-- Scrollable nav content -->
  <div class="flex-1 overflow-y-auto px-4 py-5 sm:px-6">
    {isGuide && (
      <>
        <div class="space-y-1">
          {guideSections.map(({ section, key, defaultText }) => (
            <button
              data-section={section}
              data-mobile-menu-close
              class="guide-sidebar-item w-full flex items-center rounded-xl px-3 py-3 text-left
                     text-[15px] font-bold text-white/94 transition-colors
                     hover:bg-white/[0.04] hover:text-white"
            >
              <span data-i18n={key}>{defaultText}</span>
            </button>
          ))}
        </div>
      </>
    )}

    {!isGuide && (
      <a
        href="/guide"
        class="flex items-center rounded-xl px-3 py-3.5 text-[15px] font-semibold
               text-white no-underline transition-colors
               hover:bg-white/[0.04] hover:text-white"
        data-mobile-menu-close
        data-i18n="nav.guide"
      >
        {en.nav.guide}
      </a>
    )}
  </div>

  <!-- Bottom actions -->
  <div class="shrink-0 border-t border-white/[0.06] px-4 pb-8 pt-4 sm:px-6">
    <div class="grid grid-cols-2 gap-3">
      <button
        data-lang-toggle
        type="button"
        class="inline-flex h-12 items-center justify-center rounded-2xl border border-white/[0.12]
               bg-white/[0.03] text-sm font-semibold text-white transition-colors
               hover:border-white/[0.18] hover:bg-white/[0.05]"
        aria-label="Toggle language"
      >
        <span data-lang-toggle-label>English</span>
      </button>

      <a
        href={RELEASE_DOWNLOAD_URL}
        download
        class="btn-primary inline-flex h-12 items-center justify-center rounded-2xl
               text-sm font-semibold text-white"
        data-i18n="nav.download"
      >
        {en.nav.download}
      </a>
    </div>
  </div>
</div>
