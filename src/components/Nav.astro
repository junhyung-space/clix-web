---
const DOWNLOAD_URL =
  'https://github.com/junhyung-space/clix/releases/latest/download/clix.dmg';
---

<nav
  class="sticky top-0 z-50 flex items-center justify-between px-16 py-4
         bg-bg-primary/90 border-b border-blue-muted/10 backdrop-blur-xl"
>
  <!-- Logo -->
  <a href="#" class="flex items-center gap-2.5 no-underline">
    <img
      src="/icon.png"
      alt="CLIX"
      class="w-8 h-8 rounded-lg"
    />
    <span class="font-extrabold text-base tracking-[3px] text-text-primary">
      CLIX
    </span>
  </a>

  <!-- Right -->
  <div class="flex items-center gap-4">
    <button
      id="lang-toggle"
      class="text-xs text-text-secondary border border-text-darkest/40
             rounded-full px-3 py-1 cursor-pointer hover:border-blue-muted/40
             transition-colors"
    >
      KO / EN
    </button>

    <a
      href={DOWNLOAD_URL}
      class="btn-primary text-white text-sm font-semibold
             px-4 py-2 rounded-lg transition-all duration-200"
      data-i18n="nav.download"
    >
      다운로드
    </a>
  </div>
</nav>
