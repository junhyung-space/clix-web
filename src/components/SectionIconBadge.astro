---
interface Props {
  name:
    | 'bolt'
    | 'bell'
    | 'route'
    | 'layers'
    | 'history'
    | 'terminal'
    | 'collection'
    | 'key'
    | 'network'
    | 'tunnel'
    | 'archive'
    | 'search';
  size?: 'sm' | 'md';
}

const { name, size = 'md' } = Astro.props;

const wrapperClass = size === 'sm'
  ? 'w-11 h-11'
  : 'w-14 h-14';

const svgClass = size === 'sm'
  ? 'w-5 h-5'
  : 'w-6 h-6';

const themeByName = {
  bolt: {
    color: '#F7B955',
    background: 'rgba(247, 185, 85, 0.12)',
    border: 'rgba(247, 185, 85, 0.24)',
  },
  bell: {
    color: '#67C7FF',
    background: 'rgba(103, 199, 255, 0.12)',
    border: 'rgba(103, 199, 255, 0.24)',
  },
  route: {
    color: '#8FA8FF',
    background: 'rgba(143, 168, 255, 0.12)',
    border: 'rgba(143, 168, 255, 0.24)',
  },
  layers: {
    color: '#7DD3FC',
    background: 'rgba(125, 211, 252, 0.12)',
    border: 'rgba(125, 211, 252, 0.24)',
  },
  history: {
    color: '#C4B5FD',
    background: 'rgba(196, 181, 253, 0.12)',
    border: 'rgba(196, 181, 253, 0.24)',
  },
  terminal: {
    color: '#5EEAD4',
    background: 'rgba(94, 234, 212, 0.12)',
    border: 'rgba(94, 234, 212, 0.24)',
  },
  collection: {
    color: '#93C5FD',
    background: 'rgba(147, 197, 253, 0.12)',
    border: 'rgba(147, 197, 253, 0.24)',
  },
  key: {
    color: '#86EFAC',
    background: 'rgba(134, 239, 172, 0.12)',
    border: 'rgba(134, 239, 172, 0.24)',
  },
  network: {
    color: '#FDBA74',
    background: 'rgba(253, 186, 116, 0.12)',
    border: 'rgba(253, 186, 116, 0.24)',
  },
  tunnel: {
    color: '#7DD3FC',
    background: 'rgba(125, 211, 252, 0.12)',
    border: 'rgba(125, 211, 252, 0.24)',
  },
  archive: {
    color: '#FCA5A5',
    background: 'rgba(252, 165, 165, 0.12)',
    border: 'rgba(252, 165, 165, 0.24)',
  },
  search: {
    color: '#CBD5E1',
    background: 'rgba(203, 213, 225, 0.12)',
    border: 'rgba(203, 213, 225, 0.24)',
  },
} as const;

const theme = themeByName[name];
---

<div
  class:list={[
    wrapperClass,
    'rounded-full flex items-center justify-center',
  ]}
  style={`color: ${theme.color}; background: ${theme.background}; border: 1px solid ${theme.border}; box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);`}
>
  <svg
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.9"
    stroke-linecap="round"
    stroke-linejoin="round"
    class={svgClass}
    aria-hidden="true"
  >
    {name === 'bolt' && (
      <>
        <path d="M13 2L6 13h5l-1 9 8-12h-5l0-8z" />
      </>
    )}
    {name === 'bell' && (
      <>
        <path d="M15 17H5.5a1 1 0 0 1-.8-1.6l1.3-1.7V9a5 5 0 1 1 10 0v4.7l1.3 1.7a1 1 0 0 1-.8 1.6H15" />
        <path d="M9 17a3 3 0 0 0 6 0" />
      </>
    )}
    {name === 'route' && (
      <>
        <path d="M6 6h5" />
        <path d="M13 6l2.5 2.5L13 11" />
        <path d="M18 18h-5" />
        <path d="M11 18l-2.5-2.5L11 13" />
        <path d="M8 8.5v6" />
        <path d="M16 9.5v6" />
      </>
    )}
    {name === 'layers' && (
      <>
        <path d="M12 4l8 4-8 4-8-4 8-4z" />
        <path d="M4 12l8 4 8-4" />
        <path d="M4 16l8 4 8-4" />
      </>
    )}
    {name === 'history' && (
      <>
        <path d="M4 12a8 8 0 1 0 2.3-5.7" />
        <path d="M4 4v4h4" />
        <path d="M12 8v5l3 2" />
      </>
    )}
    {name === 'terminal' && (
      <>
        <path d="M4 6l4 4-4 4" />
        <path d="M11 14h9" />
        <rect x="3" y="4" width="18" height="16" rx="2.5" />
      </>
    )}
    {name === 'collection' && (
      <>
        <rect x="3" y="5" width="8" height="6" rx="1.5" />
        <rect x="13" y="5" width="8" height="6" rx="1.5" />
        <rect x="8" y="13" width="8" height="6" rx="1.5" />
      </>
    )}
    {name === 'key' && (
      <>
        <circle cx="8" cy="12" r="3.5" />
        <path d="M11.5 12H21" />
        <path d="M17 12v3" />
        <path d="M14.5 12v2" />
      </>
    )}
    {name === 'network' && (
      <>
        <path d="M12 4v4" />
        <path d="M6 10h12" />
        <path d="M8 20v-4" />
        <path d="M16 20v-4" />
        <rect x="9" y="2.5" width="6" height="3" rx="1" />
        <rect x="4.5" y="10" width="7" height="4" rx="1" />
        <rect x="12.5" y="10" width="7" height="4" rx="1" />
        <rect x="5" y="16.5" width="6" height="3" rx="1" />
        <rect x="13" y="16.5" width="6" height="3" rx="1" />
      </>
    )}
    {name === 'tunnel' && (
      <>
        <path d="M4 17c1.8-3.3 5-5 8-5s6.2 1.7 8 5" />
        <path d="M7 13c1.2-1.4 3-2 5-2s3.8.6 5 2" />
        <path d="M10 18h4" />
        <path d="M12 6v12" />
      </>
    )}
    {name === 'archive' && (
      <>
        <rect x="3" y="5" width="18" height="4" rx="1.2" />
        <path d="M5 9v9a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V9" />
        <path d="M10 13h4" />
      </>
    )}
    {name === 'search' && (
      <>
        <circle cx="11" cy="11" r="5.5" />
        <path d="M16 16l4 4" />
      </>
    )}
  </svg>
</div>
